# Copy to `.env.local` for local dev, or `.env` for `compose.prod.yml`.
# Never commit a populated copy of this file.

# ---- Database ----
# Local dev (against the included docker-compose.yml):
DATABASE_URL="postgresql://hooks:hooks@localhost:5433/hooksfyi?schema=public"
# In compose.prod.yml the URL is built from POSTGRES_* below.
POSTGRES_USER="hooks"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="hooksfyi"

# ---- S3 / MinIO ----
# For local dev, this points at the host-mapped MinIO port.
S3_ENDPOINT="http://localhost:9100"
# When running everything in compose.prod.yml, the app reaches MinIO via the
# internal docker network instead:
S3_INTERNAL_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_BUCKET="hooks-fyi"
S3_ACCESS_KEY_ID="change-me"
S3_SECRET_ACCESS_KEY="change-me-too"
S3_FORCE_PATH_STYLE="true"

# ---- App ----
# Public origin where the dashboard is served (used to build hook URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public host that receives webhooks at /h/<id>. Often the same as APP_URL.
HOOK_PUBLIC_HOST="hooks.fyi"
# Body cap stored in DB (bytes). Anything larger gets truncated and flagged.
MAX_BODY_BYTES="1048576"
# Per-file cap for multipart uploads (bytes).
MAX_FILE_BYTES="52428800"
# Host port for compose.prod.yml's app service.
APP_PORT="3000"
