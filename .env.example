# Copy to `.env.local` for local dev, or `.env` for `compose.prod.yml`.
# Never commit a populated copy of this file.

# ---- Database ----
# Local dev (against the included docker-compose.yml):
DATABASE_URL="postgresql://hooks:hooks@localhost:5433/hooksfyi?schema=public"
# In compose.prod.yml the URL is built from POSTGRES_* below.
POSTGRES_USER="hooks"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="hooksfyi"

# ---- S3 / MinIO ----
# For local dev, this points at the host-mapped MinIO port.
S3_ENDPOINT="http://localhost:9100"
# When running everything in compose.prod.yml, the app reaches MinIO via the
# internal docker network instead:
S3_INTERNAL_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_BUCKET="hooks-fyi"
S3_ACCESS_KEY_ID="change-me"
S3_SECRET_ACCESS_KEY="change-me-too"
S3_FORCE_PATH_STYLE="true"

# ---- App ----
# Public origin where the dashboard is served (used to build hook URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public host that receives webhooks at /h/<id>. Often the same as APP_URL.
HOOK_PUBLIC_HOST="hooks.fyi"
# Bytes of the body kept inline in Postgres for fast preview. Larger bodies
# overflow to S3 as a synthetic attachment of kind=RAW_BODY.
MAX_BODY_PREVIEW_BYTES="262144"
# Hard ceiling on a single request's body. Anything larger gets rejected with
# HTTP 413 (protects the worker from OOM).
MAX_REQUEST_BYTES="104857600"
# Per-file cap for multipart uploads and body-overflow uploads (bytes).
MAX_FILE_BYTES="52428800"
# Host port for compose.prod.yml's app service.
APP_PORT="3000"

# ---- Logging ----
# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"
# "true" forces JSON to stdout, "false" forces pretty-printed output.
# When unset, JSON in production and pretty in development.
# LOG_JSON="true"

# ---- Rate limiting (per-hook) ----
# Backed by Redis. When REDIS_URL is unset the limiter is a no-op (handy in
# tests/dev). Local docker-compose exposes Redis on port 6380.
REDIS_URL="redis://localhost:6380"
# Max requests allowed per hook in each window. Set to 0 to disable.
RATE_LIMIT_PER_HOOK="100"
# Window size in seconds. Default 60s → "100/min" out of the box.
RATE_LIMIT_WINDOW_SECONDS="60"

# ---- Rate limiting (hook creation, per IP) ----
# Max POST /api/hooks per IP in each window. Set to 0 to disable.
RATE_LIMIT_CREATE_PER_IP="20"
RATE_LIMIT_CREATE_WINDOW_SECONDS="3600"

# Comma-separated CIDRs of trusted reverse proxies (e.g. "10.0.0.0/8,127.0.0.1").
# Without this, X-Forwarded-For is ignored and IPs are taken from x-real-ip
# or "unknown".
TRUSTED_PROXY_IPS=""

# Concurrent SSE streams per client IP. 0 disables the cap.
SSE_MAX_CONNECTIONS_PER_IP="20"

# --- Stale hook cleanup cron ---
# Hooks unused for this many days are deleted, along with their S3 attachments.
STALE_HOOK_RETENTION_DAYS=15
# Cron expression evaluated by Bun.cron. Default is 03:00 every day.
CLEANUP_CRON="0 3 * * *"
# Maximum number of hooks deleted per sweep. Keeps a single tick bounded.
CLEANUP_BATCH_SIZE=500
# Run an immediate sweep when the service starts (true/false).
CLEANUP_RUN_ON_START=true
