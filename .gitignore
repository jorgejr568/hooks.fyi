# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env (commit only the example)
.env
.env.*
!.env.example

# Vercel
.vercel

# Local container data
docker/minio/data/
docker/postgres/data/

# Prisma local db files
prisma/*.db

# Generated Prisma client
/src/generated/prisma

# IDE
.vscode/
.idea/
*.swp

# Local trash
.trash-*
